{
    // thesis_python workspace settings
    "python.defaultInterpreterPath": "C:/Users/leopo/anaconda3/envs/m_env/python.exe",
    "python.analysis.extraPaths": [
        "${workspaceFolder}/packages/qspectro2d/src",
